{
  "name": "garagebuild",
  "version": "0.1.0",
  "private": true,
  "description": "GarageBuild — Open AI Development Platform",
  "workspaces": [
    "packages/*",
    "packages/plugins/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "dev:desktop": "turbo run dev --filter=@garagebuild/ui-desktop",
    "dev:cli": "turbo run dev --filter=@garagebuild/cli"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "prettier": "^3.2.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.62.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@11.10.1"
}
