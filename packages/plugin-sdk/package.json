{
  "name": "@vyom/plugin-sdk",
  "version": "0.1.0",
  "description": "VYOM Plugin SDK — interfaces and types for building VYOM plugins",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
